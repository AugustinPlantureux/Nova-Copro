# ── Base de données ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/nova_copro

# ── JWT ───────────────────────────────────────────────────────
# Générer : openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32

# ── Chiffrement PII (AES-256-GCM) ────────────────────────────
# Générer : openssl rand -hex 32  (produit 64 chars hex = 32 bytes)
ENCRYPTION_KEY=change_me_64_hex_chars_aes256_key
# Clé HMAC séparée pour les lookups email
HMAC_KEY=change_me_64_hex_chars_different_from_above
# Version de clé courante (incrémenter lors d'une rotation : 1 → 2 → …)
KEY_VERSION=1
# Clés versionnées pour la rotation :
# ENCRYPTION_KEY_v1=<ancienne clé, à conserver pendant la transition>
# ENCRYPTION_KEY_v2=<nouvelle clé active>

# ── OTP ───────────────────────────────────────────────────────
# Secret HMAC pour le hashage des codes OTP (protège contre brute-force hors-ligne)
# Générer : openssl rand -base64 32
OTP_SECRET=change_me_random_secret_min_32_chars

# ── Google Drive ──────────────────────────────────────────────
# Coller le JSON credentials sur UNE seule ligne
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@votre-domaine.com
# Email de l'admin qui reçoit les demandes d'accès
ADMIN_EMAIL=votre@email.com

# ── App ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# Emails protégés contre la révocation automatique Drive (virgule-séparés)
# Ex: toi@domain.fr,gestionnaire@domain.fr,comptable@domain.fr
SYNC_PROTECTED_EMAILS=
NODE_ENV=development
PORT=3001
